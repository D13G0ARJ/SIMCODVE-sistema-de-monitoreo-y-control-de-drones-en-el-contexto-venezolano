@startuml secuencia_iniciar
title Figura 6.3 - Diagrama de secuencia: iniciar simulación - SIMCODVE
skinparam shadowing false
skinparam defaultFontName Arial

actor "Operador académico" as Op
participant "Interfaz gráfica" as UI
participant "Motor de simulación" as Motor
participant "DronSimulado" as Dron
participant "Servicio de telemetría" as Tele
participant "VistaRadar" as Radar
participant "GestorMétricas" as Met

Op -> UI : iniciar simulación
UI -> Motor : iniciar()
activate Motor
Motor -> Dron : crear / activar unidades
activate Dron
loop cada paso de simulación
  Motor -> Dron : actualizar(posición, estado)
  Dron --> Motor : telemetría sintética
  Motor -> Tele : publicar telemetría
  Tele -> Radar : actualizar representación
  Tele -> UI : actualizar paneles
  Motor -> Met : registrar métricas
end
deactivate Dron
deactivate Motor
@enduml
