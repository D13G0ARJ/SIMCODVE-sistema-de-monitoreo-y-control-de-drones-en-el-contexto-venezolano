@startuml casos_uso
title Figura 6.1 - Diagrama general de casos de uso - SIMCODVE
left to right direction
skinparam shadowing false
skinparam defaultFontName Arial

actor "Operador académico" as Op

rectangle "SIMCODVE (prototipo de simulación)" {
  usecase "CU-01 Configurar escenario\nde simulación" as CU1
  usecase "CU-02 Iniciar simulación" as CU2
  usecase "CU-03 Pausar / Reanudar\nsimulación" as CU3
  usecase "CU-04 Reiniciar simulación" as CU4
  usecase "CU-05 Visualizar radar" as CU5
  usecase "CU-06 Consultar telemetría\nde unidad" as CU6
  usecase "CU-07 Gestionar alertas\nsimuladas" as CU7
  usecase "CU-08 Registrar métricas\ny eventos" as CU8
  usecase "CU-09 Exportar resultados" as CU9
}

Op --> CU1
Op --> CU2
Op --> CU3
Op --> CU4
Op --> CU5
Op --> CU6
Op --> CU7
Op --> CU8
Op --> CU9

CU2 ..> CU5 : <<include>>
CU2 ..> CU8 : <<include>>
CU7 ..> CU8 : <<include>>
@enduml
