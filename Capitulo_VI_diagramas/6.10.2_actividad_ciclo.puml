@startuml actividad_ciclo
title Figura 6.2 - Diagrama de actividad: ciclo general de la simulación - SIMCODVE
skinparam shadowing false
skinparam defaultFontName Arial

start
:Cargar configuración del sistema;
:Generar escenario simulado\n(base, enjambres, zonas);
:Crear unidades tipo dron simuladas\n(gemelos digitales);
:Iniciar simulación;
repeat
  :Actualizar posición de las unidades\n(control descentralizado);
  :Generar telemetría sintética\n(posición, velocidad, batería, estado);
  :Verificar alertas\n(batería baja, pérdida de comunicación, falla);
  :Actualizar vista (mapa / radar);
  :Registrar métricas y eventos;
repeat while (¿simulación activa\ny no pausada?) is (sí)
->no;
:Finalizar / exportar resultados (CSV);
stop
@enduml
